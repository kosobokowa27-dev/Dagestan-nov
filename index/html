<html lang="ru">
<head>
    <meta charset="UTF-8">

    <!-- Адаптивное отображение на мобильных устройствах -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <meta
        name="description"
        content="Самые красивые и популярные места Дагестана: Сулакский каньон, Дербент, Гамсутль, Сарыкум и другие достопримечательности."
    >

    <title>Дагестан — путешествие, которое запомнится</title>

    <!-- Современные шрифты -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800&display=swap"
        rel="stylesheet"
    >

    <style>
        /* =========================================
           БАЗОВЫЕ НАСТРОЙКИ
        ========================================= */

        :root {
            --bg-main: #071412;
            --bg-secondary: #0d201c;
            --bg-card: rgba(255, 255, 255, 0.07);
            --bg-card-hover: rgba(255, 255, 255, 0.11);

            --text-main: #f7f4ec;
            --text-secondary: #b9c8c2;
            --text-dark: #10201c;

            --accent-green: #42d39c;
            --accent-turquoise: #20c7c5;
            --accent-gold: #f0b861;
            --accent-orange: #ef7c45;

            --border-light: rgba(255, 255, 255, 0.12);
            --shadow: 0 24px 60px rgba(0, 0, 0, 0.3);

            --container-width: 1180px;
            --border-radius-large: 32px;
            --border-radius-medium: 22px;
            --border-radius-small: 14px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            min-height: 100vh;
            overflow-x: hidden;
            font-family: "Manrope", sans-serif;
            color: var(--text-main);
            background:
                radial-gradient(
                    circle at 10% 10%,
                    rgba(32, 199, 197, 0.14),
                    transparent 28%
                ),
                radial-gradient(
                    circle at 90% 25%,
                    rgba(240, 184, 97, 0.12),
                    transparent 30%
                ),
                linear-gradient(
                    145deg,
                    var(--bg-main) 0%,
                    #091b18 45%,
                    #102a23 100%
                );
            line-height: 1.7;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: -1;
            pointer-events: none;
            opacity: 0.35;
            background-image:
                linear-gradient(
                    rgba(255, 255, 255, 0.025) 1px,
                    transparent 1px
                ),
                linear-gradient(
                    90deg,
                    rgba(255, 255, 255, 0.025) 1px,
                    transparent 1px
                );
            background-size: 48px 48px;
            mask-image: linear-gradient(to bottom, black, transparent);
        }

        img {
            display: block;
            max-width: 100%;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button,
        a {
            -webkit-tap-highlight-color: transparent;
        }

        .container {
            width: min(var(--container-width), calc(100% - 40px));
            margin-inline: auto;
        }

        /* =========================================
           НАВИГАЦИЯ
        ========================================= */

        .navigation {
            position: fixed;
            top: 18px;
            left: 50%;
            z-index: 1000;
            width: min(920px, calc(100% - 32px));
            padding: 12px 14px;
            transform: translateX(-50%);
            border: 1px solid var(--border-light);
            border-radius: 999px;
            background: rgba(7, 20, 18, 0.72);
            box-shadow: 0 14px 50px rgba(0, 0, 0, 0.22);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
        }

        .navigation__inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            font-weight: 800;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .logo__icon {
            display: grid;
            width: 38px;
            height: 38px;
            place-items: center;
            border-radius: 50%;
            color: var(--text-dark);
            background: linear-gradient(
                135deg,
                var(--accent-green),
                var(--accent-gold)
            );
            box-shadow: 0 8px 22px rgba(66, 211, 156, 0.22);
        }

        .navigation__links {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .navigation__links a {
            padding: 9px 14px;
            border-radius: 999px;
            color: var(--text-secondary);
            font-size: 13px;
            font-weight: 600;
            transition:
                color 0.25s ease,
                background 0.25s ease;
        }

        .navigation__links a:hover {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.08);
        }

        /* =========================================
           ГЛАВНЫЙ ЭКРАН
        ========================================= */

        .hero {
            position: relative;
            display: flex;
            min-height: 100vh;
            align-items: center;
            padding: 145px 0 90px;
        }

        .hero__content {
            position: relative;
            z-index: 2;
            max-width: 980px;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 24px;
            padding: 9px 15px;
            border: 1px solid rgba(66, 211, 156, 0.28);
            border-radius: 999px;
            color: #a9efd5;
            background: rgba(66, 211, 156, 0.08);
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .eyebrow::before {
            content: "";
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent-green);
            box-shadow: 0 0 18px var(--accent-green);
        }

        .hero__title {
            max-width: 1050px;
            font-family: "Playfair Display", serif;
            font-size: clamp(54px, 9vw, 122px);
            line-height: 0.9;
            letter-spacing: -0.055em;
        }

        .hero__title-line {
            display: block;
        }

        /*
          Градиентный заголовок с эффектом
          прозрачного текста
        */
        .hero__title-accent {
            color: transparent;
            background:
                linear-gradient(
                    90deg,
                    #ffffff 0%,
                    #77e5bd 28%,
                    #2fc6c4 58%,
                    #f2c26f 100%
                );
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 14px 35px rgba(32, 199, 197, 0.15));
        }

        .hero__description {
            max-width: 780px;
            margin-top: 34px;
            color: var(--text-secondary);
            font-size: clamp(17px, 2vw, 21px);
        }

        .hero__description strong {
            color: var(--text-main);
        }

        .hero__actions {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            margin-top: 38px;
        }

        .button {
            display: inline-flex;
            min-height: 54px;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 14px 22px;
            border: 1px solid transparent;
            border-radius: 999px;
            font-size: 15px;
            font-weight: 800;
            transition:
                transform 0.25s ease,
                box-shadow 0.25s ease,
                background 0.25s ease;
        }

        .button:hover {
            transform: translateY(-3px);
        }

        .button--primary {
            color: var(--text-dark);
            background: linear-gradient(
                135deg,
                var(--accent-green),
                var(--accent-gold)
            );
            box-shadow: 0 14px 35px rgba(66, 211, 156, 0.2);
        }

        .button--primary:hover {
            box-shadow: 0 18px 45px rgba(66, 211, 156, 0.3);
        }

        .button--secondary {
            border-color: var(--border-light);
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(14px);
        }

        .button--secondary:hover {
            background: rgba(255, 255, 255, 0.11);
        }

        .hero__facts {
            display: grid;
            max-width: 850px;
            margin-top: 62px;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }

        .fact {
            padding: 20px;
            border: 1px solid var(--border-light);
            border-radius: var(--border-radius-medium);
            background: rgba(255, 255, 255, 0.055);
            backdrop-filter: blur(15px);
        }

        .fact__value {
            display: block;
            margin-bottom: 5px;
            color: var(--accent-gold);
            font-size: 24px;
            font-weight: 800;
        }

        .fact__label {
            color: var(--text-secondary);
            font-size: 13px;
        }

        .hero__decoration {
            position: absolute;
            right: -180px;
            bottom: 60px;
            width: 520px;
            height: 520px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 50%;
            background:
                radial-gradient(
                    circle at 40% 40%,
                    rgba(66, 211, 156, 0.18),
                    transparent 55%
                );
            filter: blur(2px);
        }

        .hero__decoration::before,
        .hero__decoration::after {
            content: "";
            position: absolute;
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: inherit;
        }

        .hero__decoration::before {
            inset: 70px;
        }

        .hero__decoration::after {
            inset: 145px;
        }

        /* =========================================
           ОБЩИЕ ЗАГОЛОВКИ СЕКЦИЙ
        ========================================= */

        .section {
            padding: 105px 0;
        }

        .section-heading {
            display: grid;
            margin-bottom: 46px;
            grid-template-columns: 0.75fr 1.25fr;
            gap: 50px;
            align-items: end;
        }

        .section-heading__label {
            margin-bottom: 12px;
            color: var(--accent-green);
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }

        .section-heading__title {
            font-family: "Playfair Display", serif;
            font-size: clamp(38px, 5vw, 67px);
            line-height: 1.03;
            letter-spacing: -0.035em;
        }

        .section-heading__text {
            max-width: 620px;
            justify-self: end;
            color: var(--text-secondary);
            font-size: 17px;
        }

        /* =========================================
           ВВОДНЫЙ АКЦЕНТНЫЙ БЛОК
        ========================================= */

        .intro-card {
            position: relative;
            overflow: hidden;
            padding: clamp(30px, 5vw, 62px);
            border: 1px solid rgba(240, 184, 97, 0.23);
            border-radius: var(--border-radius-large);
            background:
                linear-gradient(
                    135deg,
                    rgba(240, 184, 97, 0.14),
                    rgba(66, 211, 156, 0.07)
                );
            box-shadow: var(--shadow);
        }

        .intro-card::before {
            content: "“";
            position: absolute;
            top: -42px;
            right: 35px;
            color: rgba(255, 255, 255, 0.05);
            font-family: "Playfair Display", serif;
            font-size: 260px;
            line-height: 1;
        }

        .intro-card__text {
            position: relative;
            z-index: 1;
            max-width: 960px;
            font-family: "Playfair Display", serif;
            font-size: clamp(25px, 4vw, 44px);
            line-height: 1.28;
        }

        .intro-card__text span {
            color: var(--accent-gold);
        }

        /* =========================================
           КАРТОЧКИ ДОСТОПРИМЕЧАТЕЛЬНОСТЕЙ
        ========================================= */

        .places-grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 20px;
        }

        .place-card {
            position: relative;
            min-height: 390px;
            overflow: hidden;
            padding: 28px;
            border: 1px solid var(--border-light);
            border-radius: var(--border-radius-large);
            background:
                linear-gradient(
                    160deg,
                    rgba(255, 255, 255, 0.09),
                    rgba(255, 255, 255, 0.035)
                );
            box-shadow: 0 16px 45px rgba(0, 0, 0, 0.18);
            transition:
                transform 0.35s ease,
                border-color 0.35s ease,
                background 0.35s ease;
        }

        .place-card:hover {
            transform: translateY(-8px);
            border-color: rgba(66, 211, 156, 0.34);
            background:
                linear-gradient(
                    160deg,
                    rgba(255, 255, 255, 0.13),
                    rgba(255, 255, 255, 0.055)
                );
        }

        .place-card:nth-child(1),
        .place-card:nth-child(4),
        .place-card:nth-child(7),
        .place-card:nth-child(10) {
            grid-column: span 7;
        }

        .place-card:nth-child(2),
        .place-card:nth-child(3),
        .place-card:nth-child(5),
        .place-card:nth-child(6),
        .place-card:nth-child(8),
        .place-card:nth-child(9) {
            grid-column: span 5;
        }

        .place-card__number {
            display: inline-grid;
            width: 50px;
            height: 50px;
            margin-bottom: 45px;
            place-items: center;
            border: 1px solid rgba(255, 255, 255, 0.14);
            border-radius: 50%;
            color: var(--accent-gold);
            background: rgba(255, 255, 255, 0.06);
            font-size: 15px;
            font-weight: 800;
        }

        .place-card__icon {
            position: absolute;
            top: 24px;
            right: 26px;
            font-size: 42px;
            filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.24));
        }

        .place-card__title {
            max-width: 470px;
            margin-bottom: 17px;
            font-family: "Playfair Display", serif;
            font-size: clamp(28px, 3vw, 40px);
            line-height: 1.05;
        }

        .place-card__subtitle {
            display: block;
            margin-top: 8px;
            color: var(--accent-green);
            font-family: "Manrope", sans-serif;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .place-card__text {
            max-width: 620px;
            color: var(--text-secondary);
            font-size: 15px;
        }

        .place-card__highlight {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 22px;
            padding: 8px 12px;
            border-radius: 999px;
            color: #d9fff1;
            background: rgba(66, 211, 156, 0.09);
            font-size: 12px;
            font-weight: 700;
        }

        .place-card__highlight::before {
            content: "";
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent-green);
        }

        /*
          Разные акцентные оттенки для карточек
        */
        .place-card:nth-child(3n + 2) {
            background:
                linear-gradient(
                    160deg,
                    rgba(32, 199, 197, 0.11),
                    rgba(255, 255, 255, 0.035)
                );
        }

        .place-card:nth-child(3n) {
            background:
                linear-gradient(
                    160deg,
                    rgba(240, 184, 97, 0.11),
                    rgba(255, 255, 255, 0.035)
                );
        }

        /* =========================================
           ПРИЧИНЫ ПОЕХАТЬ
        ========================================= */

        .reasons {
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border-light);
            border-radius: var(--border-radius-large);
            background:
                linear-gradient(
                    125deg,
                    rgba(66, 211, 156, 0.12),
                    rgba(255, 255, 255, 0.045)
                );
            box-shadow: var(--shadow);
        }

        .reasons__header {
            display: grid;
            padding: clamp(32px, 6vw, 70px);
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            border-bottom: 1px solid var(--border-light);
        }

        .reasons__title {
            font-family: "Playfair Display", serif;
            font-size: clamp(38px, 5vw, 68px);
            line-height: 1;
        }

        .reasons__text {
            align-self: end;
            color: var(--text-secondary);
            font-size: 17px;
        }

        .reasons__grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
        }

        .reason {
            min-height: 250px;
            padding: 34px;
            border-right: 1px solid var(--border-light);
            transition: background 0.3s ease;
        }

        .reason:last-child {
            border-right: none;
        }

        .reason:hover {
            background: rgba(255, 255, 255, 0.055);
        }

        .reason__icon {
            margin-bottom: 28px;
            font-size: 35px;
        }

        .reason__title {
            margin-bottom: 12px;
            font-size: 19px;
            font-weight: 800;
        }

        .reason__text {
            color: var(--text-secondary);
            font-size: 14px;
        }

        /* =========================================
           ФИНАЛЬНЫЙ ПРИЗЫВ
        ========================================= */

        .cta {
            padding: 110px 0 130px;
            text-align: center;
        }

        .cta__content {
            position: relative;
            overflow: hidden;
            padding: clamp(50px, 8vw, 100px) 30px;
            border: 1px solid rgba(240, 184, 97, 0.25);
            border-radius: var(--border-radius-large);
            background:
                radial-gradient(
                    circle at 50% 120%,
                    rgba(240, 184, 97, 0.22),
                    transparent 42%
                ),
                linear-gradient(
                    145deg,
                    rgba(255, 255, 255, 0.085),
                    rgba(255, 255, 255, 0.035)
                );
            box-shadow: var(--shadow);
        }

        .cta__label {
            margin-bottom: 18px;
            color: var(--accent-gold);
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.13em;
            text-transform: uppercase;
        }

        .cta__title {
            max-width: 850px;
            margin-inline: auto;
            font-family: "Playfair Display", serif;
            font-size: clamp(40px, 6vw, 76px);
            line-height: 1;
            letter-spacing: -0.04em;
        }

        .cta__text {
            max-width: 700px;
            margin: 25px auto 0;
            color: var(--text-secondary);
            font-size: 17px;
        }

        .cta .button {
            margin-top: 34px;
        }

        /* =========================================
           ПОДВАЛ
        ========================================= */

        .footer {
            padding: 28px 0;
            border-top: 1px solid var(--border-light);
        }

        .footer__inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            color: var(--text-secondary);
            font-size: 13px;
        }

        .footer__accent {
            color: var(--accent-green);
            font-weight: 700;
        }

        /* =========================================
           АНИМАЦИЯ ПОЯВЛЕНИЯ
        ========================================= */

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition:
                opacity 0.8s ease,
                transform 0.8s ease;
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* =========================================
           АДАПТИВНОСТЬ
        ========================================= */

        @media (max-width: 960px) {
            .navigation__links {
                display: none;
            }

            .hero {
                min-height: auto;
                padding-top: 150px;
            }

            .hero__facts {
                grid-template-columns: 1fr;
                max-width: 560px;
            }

            .section-heading {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .section-heading__text {
                justify-self: start;
            }

            .place-card,
            .place-card:nth-child(n) {
                grid-column: span 6;
            }

            .reasons__header {
                grid-template-columns: 1fr;
            }

            .reasons__grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .reason:nth-child(2) {
                border-right: none;
            }

            .reason:nth-child(-n + 2) {
                border-bottom: 1px solid var(--border-light);
            }
        }

        @media (max-width: 680px) {
            .container {
                width: min(100% - 24px, var(--container-width));
            }

            .navigation {
                top: 10px;
                width: calc(100% - 20px);
                padding: 9px 12px;
            }

            .logo {
                font-size: 12px;
            }

            .logo__icon {
                width: 34px;
                height: 34px;
            }

            .hero {
                padding: 125px 0 70px;
            }

            .hero__title {
                font-size: clamp(50px, 18vw, 82px);
            }

            .hero__description {
                margin-top: 26px;
                font-size: 16px;
            }

            .hero__actions {
                flex-direction: column;
            }

            .button {
                width: 100%;
            }

            .hero__facts {
                margin-top: 42px;
            }

            .section {
                padding: 72px 0;
            }

            .section-heading {
                margin-bottom: 30px;
            }

            .intro-card {
                border-radius: 24px;
            }

            .places-grid {
                display: block;
            }

            .place-card {
                min-height: 0;
                margin-bottom: 16px;
                padding: 24px;
                border-radius: 24px;
            }

            .place-card__number {
                margin-bottom: 55px;
            }

            .place-card__title {
                font-size: 31px;
            }

            .reasons {
                border-radius: 24px;
            }

            .reasons__grid {
                grid-template-columns: 1fr;
            }

            .reason,
            .reason:nth-child(n) {
                min-height: auto;
                border-right: none;
                border-bottom: 1px solid var(--border-light);
            }

            .reason:last-child {
                border-bottom: none;
            }

            .cta {
                padding: 75px 0 90px;
            }

            .cta__content {
                border-radius: 24px;
            }

            .footer__inner {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        /*
          Уменьшение анимации для пользователей,
          отключивших ее в настройках устройства
        */
        @media (prefers-reduced-motion: reduce) {
            html {
                scroll-behavior: auto;
            }

            *,
            *::before,
            *::after {
                transition-duration: 0.01ms !important;
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
            }

            .reveal {
                opacity: 1;
                transform: none;
            }
        }
    </style>
</head>

<body>

    <!-- Навигация -->
